#!/usr/bin/env python3
import json
import os
import sys
from datetime import datetime, timezone

# Allow imports from the project root
sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))
from skills.saf_core.lib.domains import (
    ARCHETYPE_ACTIONS,
    ARCHETYPE_KEYWORDS,
    CONFIG_PATH,
    DEFAULT_PHASES,
    DEFAULT_WORK_DAYS,
    USER_STATE_PATH,
)
from skills.saf_core.lib import paths

DAY_NAMES = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]


def _detect_system_timezone():
    """Attempts to detect the system's local timezone name."""
    try:
        return datetime.now(timezone.utc).astimezone().tzinfo.key
    except AttributeError:
        return None


def _ask_timezone():
    detected = _detect_system_timezone()
    if detected:
        tz = input(f"Enter your timezone [{detected}]: ").strip()
        return tz if tz else detected
    return input("Enter your timezone (e.g., Europe/Berlin, US/Eastern): ").strip() or "UTC"


def _ask_work_days():
    print("Default work days: Monday-Friday")
    customize = input("Customize work days? (y/N): ").strip().lower()
    if customize != "y":
        return DEFAULT_WORK_DAYS

    print("Enter work day numbers separated by commas:")
    for i, name in enumerate(DAY_NAMES):
        print(f"  {i} = {name}")
    raw = input("Work days [0,1,2,3,4]: ").strip()
    if not raw:
        return DEFAULT_WORK_DAYS
    try:
        days = [int(d.strip()) for d in raw.split(",")]
        return [d for d in days if 0 <= d <= 6]
    except ValueError:
        print("Invalid input, using defaults.")
        return DEFAULT_WORK_DAYS


def bootstrap():
    print("Initializing Situation Awareness Framework (SAF)...")

    # Check if SAF structure already exists
    history_exists = os.path.isdir("memory/domains")

    if history_exists:
        print("Existing SAF structure found at memory/domains/.")
        print("Re-running bootstrap will not overwrite existing domain data.")

    # --- Domain archetype selection ---
    print("\nPlease choose a starting Archetype:")
    print("1. Professional (Work, Projects, Infrastructure)")
    print("2. Family & Personal (Family, Home, Health)")
    print("3. Custom (Manual entry)")

    choice = input("Select (1/2/3): ").strip()
    if choice == "1":
        domains = ["Work", "Projects", "Infrastructure"]
        router_keywords = ARCHETYPE_KEYWORDS["professional"]
        proactive_actions = ARCHETYPE_ACTIONS["professional"]
    elif choice == "2":
        domains = ["Family", "Home", "Health"]
        router_keywords = ARCHETYPE_KEYWORDS["family"]
        proactive_actions = ARCHETYPE_ACTIONS["family"]
    elif choice == "3":
        raw = input("Enter domain names separated by commas: ").strip()
        domains = [d.strip() for d in raw.split(",") if d.strip()]
        if not domains:
            print("No domains provided. Aborting.")
            return
        router_keywords = {d.lower(): [] for d in domains}
        proactive_actions = {}
        print("Note: Custom domains have empty keyword lists.")
        print(f"Edit {CONFIG_PATH} to add keywords.")
    else:
        print(f"Invalid choice: {choice}. Aborting.")
        return

    # --- Temporal configuration ---
    print("\n--- Temporal Configuration ---")
    user_timezone = _ask_timezone()
    work_days = _ask_work_days()

    # --- Create domain directories ---
    os.makedirs("memory/domains", exist_ok=True)
    for d in domains:
        path = f"memory/domains/{d.lower()}"
        os.makedirs(path, exist_ok=True)
        setup_file = f"{path}/setup.md"
        if not os.path.exists(setup_file):
            with open(setup_file, "w") as f:
                f.write(f"# {d} Domain\n\nGenerated via SAF Bootstrap.")

    # --- Create router config (skip if exists to preserve customizations) ---
    os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
    if os.path.exists(CONFIG_PATH):
        print(f"Router config already exists at {CONFIG_PATH}, skipping.")
    else:
        with open(CONFIG_PATH, 'w') as f:
            json.dump(router_keywords, f, indent=2)
        print(f"Router config written to {CONFIG_PATH}")

    # --- Create user state (skip if exists to preserve customizations) ---
    if os.path.exists(USER_STATE_PATH):
        print(f"User state already exists at {USER_STATE_PATH}, skipping.")
    else:
        user_state = {
            "timezone": user_timezone,
            "work_days": work_days,
            "phases": DEFAULT_PHASES,
        }
        with open(USER_STATE_PATH, 'w') as f:
            json.dump(user_state, f, indent=2)
        print(f"User state written to {USER_STATE_PATH}")

    # --- Create proactive actions registry (skip if exists) ---
    actions_path = paths.resolve(paths.PROACTIVE_ACTIONS_FILE)
    if os.path.exists(actions_path):
        print(f"Proactive actions already exist at {actions_path}, skipping.")
    else:
        with open(actions_path, 'w') as f:
            json.dump({"actions": proactive_actions}, f, indent=2)
        print(f"Proactive actions written to {actions_path}")

    # --- Create _system domain for self-improvement engine ---
    system_dir = paths.resolve(paths.SYSTEM_DOMAIN_DIR)
    os.makedirs(system_dir, exist_ok=True)
    review_queue = paths.resolve(paths.REVIEW_QUEUE_FILE)
    if not os.path.exists(review_queue):
        with open(review_queue, "w") as f:
            f.write("# Review Queue\n\n_No pending items._\n")
        print(f"Review queue created at {review_queue}")

    print(f"\nSAF structure created with domains: {', '.join(domains)}")
    print(f"Timezone: {user_timezone}")
    print(f"Work days: {', '.join(DAY_NAMES[d] for d in work_days)}")


if __name__ == "__main__":
    bootstrap()
