#!/usr/bin/env python3
import os


def bootstrap():
    print("Initializing Situation Awareness Framework (SAF)...")

    # Check if SAF structure already exists
    history_exists = os.path.isdir("memory/domains")

    if history_exists:
        print("Existing SAF structure found at memory/domains/.")
        print("Re-running bootstrap will not overwrite existing domain data.")

    print("Please choose a starting Archetype:")
    print("1. Professional (Work, Projects, Infrastructure)")
    print("2. Family & Personal (Family, Home, Health)")
    print("3. Custom (Manual entry)")

    choice = input("Select (1/2/3): ").strip()
    if choice == "1":
        domains = ["Work", "Projects", "Infrastructure"]
    elif choice == "2":
        domains = ["Family", "Home", "Health"]
    elif choice == "3":
        raw = input("Enter domain names separated by commas: ").strip()
        domains = [d.strip() for d in raw.split(",") if d.strip()]
        if not domains:
            print("No domains provided. Aborting.")
            return
    else:
        print(f"Invalid choice: {choice}. Aborting.")
        return

    # Create structure
    os.makedirs("memory/domains", exist_ok=True)
    for d in domains:
        path = f"memory/domains/{d.lower()}"
        os.makedirs(path, exist_ok=True)
        setup_file = f"{path}/setup.md"
        if not os.path.exists(setup_file):
            with open(setup_file, "w") as f:
                f.write(f"# {d} Domain\n\nGenerated via SAF Bootstrap.")

    print(f"SAF structure created with domains: {', '.join(domains)}")


if __name__ == "__main__":
    bootstrap()
